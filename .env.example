# LLM Providers (at least one required)
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
OPENROUTER_API_KEY=your_openrouter_key_here

# Default model
MIDCLAW_MODEL=claude-sonnet-4-6

# Vault path (default: ~/.midclaw/vault)
MIDCLAW_VAULT_PATH=

# Brain HTTP bridge
BRAIN_HOST=127.0.0.1
BRAIN_PORT=7432

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

# Slack (optional)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
